<div class="home-form">
	<div class="form-row">
		<div class="form-col">
			<p><span>Nom :</span><span class="wpcf7-form-control-wrap" data-name="nom"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-text wpcf7-validates-as-required" autocomplete="name" aria-required="true" aria-invalid="false" placeholder="Saisissez votre nom" value="" type="text" name="nom" /></span>
			</p>
		</div>
		<div class="form-col">
			<p><span>Prénom :</span><span class="wpcf7-form-control-wrap" data-name="prenom"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-text wpcf7-validates-as-required" aria-required="true" aria-invalid="false" placeholder="Saisissez votre prénom" value="" type="text" name="prenom" /></span>
			</p>
		</div>
	</div>
	<div class="form-row">
		<div class="form-col">
			<p><span>Adresse Email :</span><span class="wpcf7-form-control-wrap" data-name="email"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email" aria-required="true" aria-invalid="false" placeholder="Saisissez votre adresse email" value="" type="email" name="email" /></span>
			</p>
		</div>
		<div class="form-col">
			<p><span>Téléphone :</span><span class="wpcf7-form-control-wrap" data-name="tel"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-tel wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-tel" aria-required="true" aria-invalid="false" placeholder="Saisissez votre numéro téléphone" value="" type="tel" name="tel" /></span>
			</p>
		</div>
	</div>
	<div class="form-row">
		<div class="form-col">
			<p><span>Sujet :</span><span class="wpcf7-form-control-wrap" data-name="sujet"><input size="40" maxlength="400" class="wpcf7-form-control wpcf7-text wpcf7-validates-as-required" autocomplete="name" aria-required="true" aria-invalid="false" placeholder="Saisissez votre sujet" value="" type="text" name="sujet" /></span>
			</p>
