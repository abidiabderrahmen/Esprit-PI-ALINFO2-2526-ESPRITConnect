	<div class="form-row">
		<div class="form-col">
			<p><span>Service :</span><span class="wpcf7-form-control-wrap" data-name="service"><select class="wpcf7-form-control wpcf7-select wpcf7-validates-as-required" aria-required="true" aria-invalid="false" name="service"><option value="">-Sélectionnez-</option><option value="Admission">Admission</option><option value="Etudes">Etudes</option><option value="Finance">Finance</option><option value="Scolarité">Scolarité</option><option value="Communication">Communication</option></select></span>
			</p>
